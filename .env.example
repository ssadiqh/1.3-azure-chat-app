# 1.3 Claude Chat App - Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
MODEL_DEPLOYMENT=gpt-5.4

# Chat Configuration
MAX_TOKENS=1024

# Authentication Method
# Choose one: key, cli, env, browser, managed, device, default
#
# key      = AzureKeyCredential (requires AZURE_OPENAI_API_KEY)
# cli      = AzureCliCredential (requires: az login)
# env      = EnvironmentCredential (requires: AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET)
# browser  = InteractiveBrowserCredential (opens browser for login)
# managed  = ManagedIdentityCredential (only in Azure, not local)
# device   = DeviceCodeCredential (device code flow)
# default  = DefaultAzureCredential (tries all methods) - RECOMMENDED
#
AZURE_AUTH_METHOD=default

# For 'key' authentication method only
AZURE_OPENAI_API_KEY=

# For 'env' authentication method only (CI/CD pipelines)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret